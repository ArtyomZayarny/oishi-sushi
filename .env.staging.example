# ---------------------------------------------------------------------------
# Staging environment template (Railway). NOT auto-loaded — copy these into the
# Railway service "Variables" (api vars on the api service, web vars on the web
# service). Two services, one repo, one public origin: the web service proxies
# /api and /socket.io to the private api over Railway's internal network.
# ---------------------------------------------------------------------------

# ===== api service =====
# Postgres — prefer Railway's reference "${{Postgres.DATABASE_URL}}" over a literal.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Long random string; changing it invalidates all existing sessions.
JWT_SECRET=replace-with-a-64-char-random-secret
# Public web origin(s) allowed for CORS + WebSocket (comma-separated, no spaces).
# Set to the web service's public URL.
CORS_ORIGINS=https://your-app.up.railway.app
# HTTPS staging → cookies MUST be Secure or the browser silently drops the
# session and login appears to fail.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# Anthropic — OUR capped staging key (NOT the owner's production key).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
SOMMELIER_MODEL=claude-opus-4-8
# Daily token kill-switch — keep staging well below prod (default 500000) so an
# abusive demo cannot run up cost. ~100k tokens/day is plenty for a demo.
SOMMELIER_DAILY_TOKEN_BUDGET=100000
# Optional overrides (else code defaults 25000 / 1000 / 5 / 40):
# SOMMELIER_TIMEOUT_MS=25000
# SOMMELIER_MAX_TOKENS=1000
# SOMMELIER_THROTTLE_LIMIT=5
# SOMMELIER_GLOBAL_THROTTLE_LIMIT=40

# ===== web service =====
# Private address of the api service (Railway internal DNS). Browser traffic is
# proxied here; server-side (SSR) fetches hit API_BASE_URL directly.
API_PROXY_TARGET=http://api.railway.internal:3000
API_BASE_URL=http://api.railway.internal:3000/api
# Angular SSR validates the request Host header. Set this to the PUBLIC web
# domain(s) (comma-separated, hostname only — no scheme/port) or SSR rejects the
# request and silently falls back to client-side rendering. Use the Railway URL.
NG_ALLOWED_HOSTS=your-app.up.railway.app
# Password gate "user:pass" — REQUIRED on staging so the demo URL isn't public.
STAGING_BASIC_AUTH=demo:change-me-please
# Railway injects PORT automatically; only set to override locally.
# PORT=4000
