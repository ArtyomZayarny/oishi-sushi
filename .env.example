DATABASE_URL="postgresql://oishi:oishi_dev_pass@localhost:5432/oishi?schema=public"
JWT_SECRET="change-me-32-chars-minimum-for-hs256"
COOKIE_DOMAIN="localhost"
NODE_ENV="development"
API_PORT="3000"
WEB_PORT="4200"
WEB_SSR_PORT="4000"

# --- Sommelier (AI) — §9 of the MVP spec -------------------------------------
# Required for LIVE answers; OPTIONAL in dev/CI. Leave blank and the app still
# boots and the route returns its canned response (it 503s only once the LLM
# path lands in T7). The live eval (`nx run api:eval`) needs a real key.
ANTHROPIC_API_KEY=
# Model id used for grounded generation. One-line swap to claude-sonnet-4-6 if
# volume/latency demands.
SOMMELIER_MODEL="claude-opus-4-8"
# Server-side Anthropic call timeout, in milliseconds.
SOMMELIER_TIMEOUT_MS="25000"
# Max tokens for the model response (keep small — compact, grounded answers).
SOMMELIER_MAX_TOKENS="1000"
# Per-IP rate limit (requests/min) on POST /api/sommelier. Raise for e2e/demo.
SOMMELIER_THROTTLE_LIMIT="5"
# App-wide rate cap (requests/min) on the sommelier route — cost guard across
# all IPs, independent of the per-IP limit.
SOMMELIER_GLOBAL_THROTTLE_LIMIT="40"
# Daily token kill-switch: once the day's summed usage exceeds this, the route
# returns 503 SOMMELIER_UNAVAILABLE until UTC-midnight reset (warns at 50%).
SOMMELIER_DAILY_TOKEN_BUDGET="500000"
